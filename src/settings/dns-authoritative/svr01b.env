# DNS Authoritative inventory.
#
# This role exposes authoritative DNS through BACK/VIP and is not consumed
# directly by external clients.

ROLE="dns-authoritative"
NODE_NAME="svr01b"

BACK_IP="REPLACE_BACK_IP"
ADM_IP="REPLACE_ADM_IP"
VIP_BACK_IP="REPLACE_VIP_BACK_IP"
PEER_BACK_IP="REPLACE_PEER_BACK_IP"

PROXY_TRANSFER_CLIENTS="REPLACE_PROXY_BACK_IP_1; REPLACE_PROXY_BACK_IP_2;"
ADM_ALLOWED_CLIENTS="REPLACE_ADM_CIDR"

KEEPALIVED_INTERFACE="REPLACE_BACK_INTERFACE"
KEEPALIVED_STATE="BACKUP"
KEEPALIVED_PRIORITY="100"
KEEPALIVED_VRID="51"
KEEPALIVED_AUTH_PASS="CHANGE_ME"

TSIG_KEY_NAME="xfr-shared-key"
TSIG_SECRET="CHANGE_ME_BASE64"


ENABLE_RRL="yes"
RRL_RESPONSES_PER_SECOND="20"
RRL_REFERRALS_PER_SECOND="5"
RRL_NXDOMAINS_PER_SECOND="10"
RRL_ERRORS_PER_SECOND="10"
RRL_WINDOW="5"

ENABLE_DNSSEC="no"
DNSSEC_POLICY_NAME="binddns-default"
DNSSEC_KEY_DIRECTORY="/var/named/dnssec"
DNSSEC_SIGNING_MODE="policy"

BINDDNS_VERSION="5.0"

# RNDC:
#   RNDC_KEY_NAME defaults to "rndc-key".
#   RNDC_SECRET is generated automatically if not defined.
