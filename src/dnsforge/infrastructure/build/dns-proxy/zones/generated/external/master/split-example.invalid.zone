$TTL 3600

@       IN SOA  ns.split-example.invalid. hostmaster.split-example.invalid. (

                2026060601 ; serial
                3600       ; refresh
                900        ; retry
                1209600    ; expire
                300        ; negative cache ttl
)

        IN NS   ns.split-example.invalid.

ns      IN A    192.0.2.53
app     IN A    192.0.2.80
