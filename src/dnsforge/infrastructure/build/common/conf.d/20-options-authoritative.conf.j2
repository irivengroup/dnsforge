options {

        directory "/var/named";

        listen-on port 53 {
                {{ BACK_IP }};
                {{ VIP_BACK_IP }};
        };

        listen-on-v6 {
                none;
        };

        allow-query {
                transfer_clients;
        };

        allow-transfer {
                none;
        };

        recursion no;

        allow-recursion {
                none;
        };

        allow-query-cache {
                none;
        };

        minimal-responses yes;

        version "not disclosed";

        hostname none;

        server-id none;

        dnssec-validation auto;

        notify yes;

        transfer-source {{ BACK_IP }};

        notify-source {{ BACK_IP }};

        rate-limit {
                responses-per-second {{ RRL_RESPONSES_PER_SECOND }};
                referrals-per-second {{ RRL_REFERRALS_PER_SECOND }};
                nxdomains-per-second {{ RRL_NXDOMAINS_PER_SECOND }};
                errors-per-second {{ RRL_ERRORS_PER_SECOND }};
                window {{ RRL_WINDOW }};
        };

        managed-keys-directory "/var/named/dynamic";

        statistics-file "/var/named/data/named_stats.txt";

        pid-file "/run/named/named.pid";
};
