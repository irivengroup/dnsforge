// DNSForge managed views.
view "internal" {
    match-clients { recursive_clients; localhost; };
    recursion yes;
    allow-recursion { recursive_clients; localhost; };
    allow-query-cache { recursive_clients; localhost; };
    allow-query { recursive_clients; localhost; };
{{ INTERNAL_RPZ_RESPONSE_POLICY }}
{{ INTERNAL_CATALOG_INCLUDE }}
{{ INTERNAL_RPZ_INCLUDE }}
    include "{{ INTERNAL_ZONE_INDEX }}";
};

view "external" {
    match-clients { any; };
    recursion no;
    allow-recursion { none; };
    allow-query-cache { none; };
    allow-query { any; };
    include "{{ EXTERNAL_ZONE_INDEX }}";
};
