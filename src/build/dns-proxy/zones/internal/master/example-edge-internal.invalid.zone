$TTL 3600

@       IN SOA  ns.example-edge-internal.invalid. hostmaster.example-edge-internal.invalid. (

                2026060601 ; serial
                3600       ; refresh
                900        ; retry
                1209600    ; expire
                300        ; negative cache ttl
)

        IN NS   ns.example-edge-internal.invalid.

ns      IN A    192.0.2.40
app     IN A    192.0.2.41
