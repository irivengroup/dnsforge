$TTL 300

@       IN SOA  localhost. root.localhost. (

                2026060601 ; serial
                3600       ; refresh
                900        ; retry
                1209600    ; expire
                300        ; negative cache ttl
)

        IN NS   localhost.

; ---------------------------------------------------------------------------
; Local RPZ policy examples
; ---------------------------------------------------------------------------
; CNAME .       => return NXDOMAIN-like policy response
; CNAME rpz-passthru. => bypass policy for a name
;
; Add one blocked domain per line and increment the SOA serial.
; ---------------------------------------------------------------------------

malware.example.invalid.        CNAME .
phishing.example.invalid.       CNAME .
tracking.example.invalid.       CNAME .
