view "external" {

        match-destinations {
                {{ FRONT_IP }};
        };

        match-clients {
                front_allowed_clients;
        };

        recursion no;

        allow-recursion {
                none;
        };

        allow-query-cache {
                none;
        };

        forward {{ DNS_FORWARD_POLICY }};

        forwarders {
                {{ AUTHORITATIVE_BACK_IP_BIND_LIST }}
        };

        include "/etc/named/views/external/master/zones.index.conf";

        include "/etc/named/views/external/secondary/zones.index.conf";

        include "/etc/named/views/external/forward/zones.index.conf";
};


view "internal" {

        match-destinations {
                {{ BACK_IP }};
        };

        match-clients {
                recursive_clients;
        };

        recursion yes;

        allow-recursion {
                recursive_clients;
        };

        allow-query-cache {
                recursive_clients;
        };

        forward {{ DNS_FORWARD_POLICY }};

        forwarders {
                {{ AUTHORITATIVE_BACK_IP_BIND_LIST }}
        };

        include "/etc/named/views/internal/master/zones.index.conf";

        include "/etc/named/views/internal/secondary/zones.index.conf";

        include "/etc/named/views/internal/forward/zones.index.conf";
        include "/etc/named/rpz/50-rpz.conf";

        include "/etc/named/rpz/rpz-zone.conf";

        include "/etc/named/views/internal/reverse/zones.index.conf";
};


view "partner" {

        match-clients {
                partner_clients;
        };

        recursion no;

        allow-query {
                partner_clients;
        };

        include "/etc/named/views/partner/master/zones.index.conf";

        include "/etc/named/views/partner/secondary/zones.index.conf";

        include "/etc/named/views/partner/forward/zones.index.conf";
};
