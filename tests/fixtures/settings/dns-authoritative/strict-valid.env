ROLE="dns-authoritative"
NODE_NAME="strict-valid"
BACK_IP="192.0.2.11"
ADM_IP="203.0.113.11"
VIP_BACK_IP="192.0.2.10"
PEER_BACK_IP="192.0.2.12"
PROXY_TRANSFER_CLIENTS="198.51.100.53; 198.51.100.54;"
ADM_ALLOWED_CLIENTS="203.0.113.0/24; localhost;"
KEEPALIVED_INTERFACE="eth1"
KEEPALIVED_STATE="MASTER"
KEEPALIVED_PRIORITY="110"
KEEPALIVED_VRID="51"
KEEPALIVED_AUTH_PASS="testpass"
TSIG_KEY_NAME="xfr-shared-key"
TSIG_SECRET="dGVzdC10c2lnLXNlY3JldA=="
ENABLE_RRL="yes"
RRL_RESPONSES_PER_SECOND="20"
RRL_REFERRALS_PER_SECOND="5"
RRL_NXDOMAINS_PER_SECOND="10"
RRL_ERRORS_PER_SECOND="10"
RRL_WINDOW="5"
ENABLE_DNSSEC="yes"
DNSSEC_POLICY_NAME="binddns-default"
DNSSEC_KEY_DIRECTORY="/var/named/dnssec"
DNSSEC_SIGNING_MODE="policy"
BINDDNS_VERSION="6.2"

# RNDC:
#   RNDC_KEY_NAME defaults to "rndc-key".
#   RNDC_SECRET is generated automatically if not defined.
