ROLE="dns-proxy"
NODE_NAME="strict-valid"
FRONT_IP="192.0.2.53"
BACK_IP="198.51.100.53"
ADM_IP="203.0.113.53"
AUTHORITATIVE_BACK_IP="192.0.2.10 ; 192.0.2.20"
AUTH_CLUSTER_A_BACK_IP="192.0.2.10"
AUTH_CLUSTER_B_BACK_IP="192.0.2.20, 192.0.2.21"
FRONT_ALLOWED_CLIENTS="any"
BACK_RECURSIVE_CLIENTS="10.0.0.0/8; localhost; localnets;"
ADM_ALLOWED_CLIENTS="203.0.113.0/24; localhost;"
PROXY_TRANSFER_CLIENTS="none;"
PARTNER_ALLOWED_CLIENTS="203.0.113.0/24; localhost;"
ZONE_ACL_PUBLIC="any;"
ZONE_ACL_INTERNAL="recursive_clients;"
ZONE_ACL_PARTNER="partner_clients;"
DNS_FORWARD_POLICY="first"
TSIG_KEY_NAME="xfr-shared-key"
TSIG_SECRET="dGVzdC10c2lnLXNlY3JldA=="
ENABLE_RPZ="yes"
RPZ_ZONE_NAME="rpz.local"
RPZ_POLICY="recursive-only yes"
RPZ_LOGGING="yes"
ENABLE_RRL="yes"
RRL_RESPONSES_PER_SECOND="10"
RRL_REFERRALS_PER_SECOND="5"
RRL_NXDOMAINS_PER_SECOND="5"
RRL_ERRORS_PER_SECOND="5"
RRL_WINDOW="5"
ENABLE_DNSSEC="yes"
DNSSEC_POLICY_NAME="binddns-default"
DNSSEC_KEY_DIRECTORY="/var/named/dnssec"
DNSSEC_SIGNING_MODE="policy"
ENABLE_PROXY_HA="yes"
PROXY_VIP_FRONT_IP="192.0.2.250/24"
PROXY_KEEPALIVED_INTERFACE="eth0"
PROXY_KEEPALIVED_STATE="MASTER"
PROXY_KEEPALIVED_PRIORITY="110"
PROXY_KEEPALIVED_VRID="61"
PROXY_KEEPALIVED_AUTH_PASS="testpass"
PROXY_HA_HEALTHCHECK_ZONE="split-example.invalid"
BINDDNS_VERSION="6.2"

# RNDC:
#   RNDC_KEY_NAME defaults to "rndc-key".
#   RNDC_SECRET is generated automatically if not defined.
